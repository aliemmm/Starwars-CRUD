@model Starwars.App.Models.ViewModels.StarshipViewModel
<h2>@Model.Name - Details</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Model</dt>
            <dd class="col-sm-8">@Model.Model</dd>

            <dt class="col-sm-4">Manufacturer</dt>
            <dd class="col-sm-8">@Model.Manufacturer</dd>

            <dt class="col-sm-4">Class</dt>
            <dd class="col-sm-8">@Model.StarshipClass</dd>

            <dt class="col-sm-4">Hyperdrive Rating</dt>
            <dd class="col-sm-8">@Model.HyperdriveRating</dd>

            <dt class="col-sm-4">Cost (Credits)</dt>
            <dd class="col-sm-8">@Model.CostInCredits</dd>
        </dl>
    </div>

    <div class="col-md-6">
        <div class="card border-primary mb-3">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <span>AI Starship Databank</span>
                <a asp-action="Details" asp-route-id="@Model.Id" id="btn-@Model.Id" asp-route-generateLore="true" class="btn btn-sm btn-light disabled">Generate Lore</a>
            </div>
            <div class="card-body">
                @if (ViewBag.AiLore != null)
                {
                    <p id="ai-content" class="card-text">@ViewBag.AiLore</p>
                }
                else
                {
                    <p id="ai-content" class="card-text text-muted">Click 'Generate Lore' to access classified AI databank files regarding this vessel.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    <script src="https://js.puter.com/v2/"></script>
    <script>
        var prompt = "Write a short, engaging, 1-paragraph sci-fi lore description for the Star Wars starship named '@Model.Name'. It is a @Model.StarshipClass manufactured by @Model.Manufacturer with a hyperdrive rating of @Model.HyperdriveRating.";
        puter.ai.chat(prompt, { model: "gpt-5.4-nano" })
           .then(response => {
               $('#ai-content').text(response);
               $('#btn-@Model.Id').removeClass('disabled');
               $('#btn-@Model.Id > i').hide();
           });
    </script>
}