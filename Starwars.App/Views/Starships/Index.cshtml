@model IReadOnlyList<Starwars.App.Models.ViewModels.StarshipViewModel>
@{ ViewData["Title"] = "Starships Directory"; }

<h2 class="mb-4">Starships Directory</h2>
<p><a asp-action="Create" class="btn btn-primary">Add New Starship</a></p>

<table id="starshipsTable" class="table table-striped table-bordered w-100">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Model</th>
            <th>Manufacturer</th>
            <th>Cost (Credits)</th>
            <th>Class</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Name</td>
                <td>@item.Model</td>
                <td>@item.Manufacturer</td>
                <td>@item.CostInCredits</td>
                <td>@item.StarshipClass</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        var starshipsTable = $('#starshipsTable');
        $(document).ready(function () {
            starshipsTable.DataTable({
                responsive: true,
                order: [[0, 'asc']]
            });
        });
    </script>
}
